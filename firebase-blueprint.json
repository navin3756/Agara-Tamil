{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing vocabulary builder progress.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "streak": {
          "type": "number",
          "description": "Current learning streak in days."
        },
        "lastPlayedDate": {
          "type": "string",
          "description": "The date the user last learned a word."
        },
        "learnedWords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of learned Tamil words."
        }
      },
      "required": ["userId", "streak"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of user profiles tracking their vocabulary progress."
    }
  }
}
