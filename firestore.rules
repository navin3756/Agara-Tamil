rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'streak', 'learnedWords']) &&
             data.userId == request.auth.uid &&
             data.streak is number &&
             data.learnedWords is list &&
             data.learnedWords.size() <= 1000 &&
             (data.keys().hasAll(['lastPlayedDate']) ? data.lastPlayedDate is string : true) &&
             data.size() <= 4;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      
      allow create: if isSignedIn() && isValidId(userId) &&
                       request.auth.uid == userId &&
                       isValidUser(incoming());

      allow update: if isSignedIn() && isValidId(userId) &&
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().userId == existing().userId &&
                       (
                         incoming().diff(existing()).affectedKeys().hasOnly(['streak', 'lastPlayedDate', 'learnedWords'])
                       );
    }
  }
}
