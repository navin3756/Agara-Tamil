rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidDate(value) { return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$'); }

    function isValidUser(data) {
      return data.keys().hasOnly(['userId', 'streak', 'learnedWords', 'lastPlayedDate']) &&
             data.keys().hasAll(['userId', 'streak', 'learnedWords']) &&
             data.userId == request.auth.uid &&
             data.streak is int &&
             data.streak >= 0 &&
             data.streak <= 3660 &&
             data.learnedWords is list &&
             data.learnedWords.size() <= 500 &&
             (data.keys().hasAll(['lastPlayedDate']) ? isValidDate(data.lastPlayedDate) : true);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      
      allow create: if isSignedIn() && isValidId(userId) &&
                       request.auth.uid == userId &&
                       isValidUser(incoming());

      allow update: if isSignedIn() && isValidId(userId) &&
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['streak', 'lastPlayedDate', 'learnedWords']);
    }
  }
}
